# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxx          # REPLACE — from Resend dashboard > API Keys
RESEND_FROM_EMAIL=noreply@send.encompassparking.com  # Requires Resend domain verification on send.encompassparking.com
CONTACT_TO_EMAIL=contact@encompassparking.com

# Resend Audiences (newsletter)
NEWSLETTER_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # REPLACE — from Resend dashboard > Audiences
NEWSLETTER_CONFIRM_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx    # REPLACE — generate with: openssl rand -hex 32

# Cloudflare Turnstile (spam protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAxxxxxxxxxxxxxxxx  # REPLACE — from Cloudflare dashboard > Turnstile
TURNSTILE_SECRET_KEY=0x4AAAxxxxxxxxxxxxxxxx             # REPLACE — from Cloudflare dashboard > Turnstile

# Cal.com (scheduling)
NEXT_PUBLIC_CAL_EVENT_URL=https://cal.com/jason-encompass/intro-call  # REPLACE — after Cal.com account setup

# Upstash Redis (rate limiting) — auto-injected by Vercel Marketplace "Upstash for Redis" integration
# These are Vercel's canonical names. KV_URL, REDIS_URL, and KV_REST_API_READ_ONLY_TOKEN are
# also written by the integration but not consumed by this project.
KV_REST_API_URL=                        # Auto-set by Vercel Marketplace integration
KV_REST_API_TOKEN=                      # Auto-set by Vercel Marketplace integration
